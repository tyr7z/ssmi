{
    "env": {
        "myIncludePath": ["${workspaceFolder}/ext", "${workspaceFolder}/build/_deps/minhook-src/include"]
    },
    "configurations": [
        {
            "name": "Win32",
            "includePath": ["${myIncludePath}", "${workspaceFolder}/**"],
            "defines": ["_DEBUG", "UNICODE", "_UNICODE"],
            "windowsSdkVersion": "10.0.26100.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "intelliSenseMode": "windows-msvc-x64",
            "browse": {
                "path": ["${myIncludePath}", "${workspaceFolder}"]
            }
        }
    ],
    "version": 4
}
